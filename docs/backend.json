
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data including preferences and library references.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid", "email"]
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document"
    }
  }
}
